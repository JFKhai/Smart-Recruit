# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development   # development | production

# ─── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Lấy từ Atlas → Connect → Drivers → copy connection string
# Nhớ thêm tên database: .../smart_recruit?...
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smart_recruit?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Có thể đặt nhiều origin, cách nhau bởi dấu phẩy
# VD production: CLIENT_ORIGIN=https://smartrecruit.vn,https://www.smartrecruit.vn
CLIENT_ORIGIN=http://localhost:3000

# ─── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ─── Gemini AI ─────────────────────────────────────────────────────────────────
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Groq AI ───────────────────────────────────────────────────────────────────
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
# Nhớ thêm callback URL: https://your-api-domain/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Facebook OAuth ────────────────────────────────────────────────────────────
# Meta Developers → App → Facebook Login → Settings
# Nhớ thêm callback URL: https://your-api-domain/api/auth/facebook/callback
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ─── Cloudflare R2 (Ngày 4 — CV Storage) ──────────────────────────────────────
# Cloudflare Dashboard → R2 → Manage R2 API Tokens
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET_NAME=smart-recruit-cvs
# R2_PUBLIC_URL=https://your-bucket.your-subdomain.r2.dev

# ─── Email / Resend (Ngày 6) ───────────────────────────────────────────────────
# https://resend.com/api-keys
# RESEND_API_KEY=re_your_resend_api_key
# SENDER_EMAIL=Smart Recruit <onboarding@resend.dev>
# FRONTEND_URL=http://localhost:3000

# ─── Sentry (Ngày 6 — Error Monitoring) ───────────────────────────────────────
# https://sentry.io → Project Settings → Client Keys
# SENTRY_DSN=https://your_dsn@sentry.io/your_project_id

# ─── Cookie Domain (tùy chọn, khi dùng subdomain) ─────────────────────────────
# COOKIE_DOMAIN=.smartrecruit.vn
